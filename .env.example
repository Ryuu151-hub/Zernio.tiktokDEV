# --- TikTok (developers.tiktok.com > Manage apps > your app > Login Kit) ---
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
# Must exactly match a redirect URI registered in the TikTok Developer Portal.
# With chrome.identity.launchWebAuthFlow this is:
#   https://<YOUR_EXTENSION_ID>.chromiumapp.org/
TIKTOK_REDIRECT_URI=https://your-extension-id.chromiumapp.org/

# --- Zernio (dashboard > API keys) ---
ZERNIO_API_KEY=your_zernio_api_key
