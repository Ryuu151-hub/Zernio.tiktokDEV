{
  "manifest_version": 3,
  "name": "Zernio TikTok Uploader",
  "version": "1.0.0",
  "description": "Log in with TikTok and post videos straight from your browser, using TikTok's official Content Posting API.",
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://open.tiktokapis.com/*",
    "https://YOUR-VERCEL-APP.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zernio TikTok Uploader",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
